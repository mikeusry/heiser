---
/**
 * FAQItem Component
 * Displays a single FAQ question and answer
 *
 * Props:
 * - question: The question text
 * - answer: The answer text
 * - variant: 'card' | 'simple' - visual style (default: 'card')
 */

interface Props {
  question: string;
  answer: string;
  variant?: 'card' | 'simple';
}

const {
  question,
  answer,
  variant = 'card',
} = Astro.props;
---

{variant === 'card' ? (
  <div class="bg-gray-50 rounded-xl p-6 md:p-8">
    <h3 class="text-lg font-heading font-bold text-brand-navy mb-3">{question}</h3>
    <p class="text-gray-600 leading-relaxed">{answer}</p>
  </div>
) : (
  <div class="border-b border-gray-200 pb-6">
    <h3 class="text-lg font-heading font-bold text-brand-navy mb-2">{question}</h3>
    <p class="text-gray-600 leading-relaxed">{answer}</p>
  </div>
)}
