---
/**
 * FeatureCard Component
 * Reusable card for displaying features/benefits with icon, title, and description
 *
 * Props:
 * - title: Feature title (required)
 * - description: Feature description (required)
 * - icon: 'star' | 'check' | 'dollar' | 'calendar' | 'sparkle' | 'team' | 'shield' | 'phone' | 'location' | 'clock'
 * - variant: 'default' | 'numbered' | 'boxed'
 * - number: Number to display (for numbered variant)
 * - iconSize: 'sm' | 'md' | 'lg'
 */

interface Props {
  title: string;
  description: string;
  icon?: 'star' | 'check' | 'dollar' | 'calendar' | 'sparkle' | 'team' | 'shield' | 'phone' | 'location' | 'clock';
  variant?: 'default' | 'numbered' | 'boxed';
  number?: number;
  iconSize?: 'sm' | 'md' | 'lg';
}

const {
  title,
  description,
  icon = 'star',
  variant = 'default',
  number,
  iconSize = 'md',
} = Astro.props;

const iconSizes = {
  sm: 'w-6 h-6',
  md: 'w-8 h-8',
  lg: 'w-12 h-12',
};

const containerSizes = {
  sm: 'w-10 h-10',
  md: 'w-12 h-12',
  lg: 'w-16 h-16',
};

const icons = {
  star: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  check: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  dollar: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  calendar: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
  sparkle: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  team: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>`,
  shield: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  phone: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
  location: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  clock: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
};

const isFilled = icon === 'star';
---

{variant === 'boxed' ? (
  <div class="bg-white p-6 rounded-xl shadow-lg">
    <h3 class="text-xl font-heading font-bold text-brand-navy mb-2">{title}</h3>
    <p class="text-gray-600">{description}</p>
  </div>
) : variant === 'numbered' ? (
  <div class="flex gap-6">
    <div class={`${containerSizes[iconSize]} bg-brand-orange rounded-full flex items-center justify-center flex-shrink-0`}>
      <span class="text-white font-bold text-2xl">{number}</span>
    </div>
    <div>
      <h3 class="text-2xl font-heading font-bold text-brand-navy mb-2">{title}</h3>
      <p class="text-gray-600 text-lg">{description}</p>
    </div>
  </div>
) : (
  <div class="flex gap-4">
    {isFilled ? (
      <svg class={`${iconSizes[iconSize]} text-brand-orange flex-shrink-0`} fill="currentColor" viewBox="0 0 24 24">
        <Fragment set:html={icons[icon]} />
      </svg>
    ) : (
      <div class={`${containerSizes[iconSize]} bg-brand-orange rounded-lg flex items-center justify-center flex-shrink-0`}>
        <svg class={`${iconSize === 'lg' ? 'w-8 h-8' : 'w-6 h-6'} text-white`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <Fragment set:html={icons[icon]} />
        </svg>
      </div>
    )}
    <div>
      <h3 class="text-xl font-heading font-bold text-brand-navy mb-2">{title}</h3>
      <p class="text-gray-600">{description}</p>
    </div>
  </div>
)}
