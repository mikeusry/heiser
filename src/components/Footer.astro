---
// Modern Footer with Navy Background
import { footerServices } from '../lib/services';
import { contact, company } from '../lib/contact';
---

<footer class="bg-brand-navy text-white py-16">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Top Section -->
    <div class="grid lg:grid-cols-4 gap-12 mb-12">
      <!-- Logo & Company Info -->
      <div class="lg:col-span-1">
        <div class="mb-6 bg-white p-4 rounded-lg">
          <img
            src="/heiser-logo-original.png"
            alt={company.name}
            class="w-full h-auto"
          />
        </div>
        <p class="text-gray-300 mb-6 text-lg leading-relaxed">
          {company.shortDescription}
        </p>
        <a
          href="/contact"
          class="inline-block bg-white text-brand-navy px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors text-lg"
        >
          Get A Quote
        </a>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="text-xl font-heading font-bold mb-6" style="color: #B0B0B0;">Services</h3>
        <ul class="space-y-3">
          {footerServices.map(service => (
            <li>
              <a href={service.url} class="text-gray-300 hover:text-white transition-colors text-lg">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="text-xl font-heading font-bold mb-6" style="color: #B0B0B0;">Company</h3>
        <ul class="space-y-3">
          <li>
            <a href="/about" class="text-gray-300 hover:text-white transition-colors text-lg">
              Our History
            </a>
          </li>
          <li>
            <a href="/service-areas" class="text-gray-300 hover:text-white transition-colors text-lg">
              Service Areas
            </a>
          </li>
          <li>
            <a href="/blog" class="text-gray-300 hover:text-white transition-colors text-lg">
              Blog
            </a>
          </li>
          <li>
            <a href="/faq" class="text-gray-300 hover:text-white transition-colors text-lg">
              FAQ
            </a>
          </li>
          <li>
            <a href="/contact" class="text-gray-300 hover:text-white transition-colors text-lg">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Outreach Column -->
      <div>
        <h3 class="text-xl font-heading font-bold mb-6" style="color: #B0B0B0;">Outreach</h3>
        <ul class="space-y-3">
          <li>
            <a href="/careers" class="text-gray-300 hover:text-white transition-colors text-lg">
              Job Openings
            </a>
          </li>
          <li>
            <a href={contact.social.facebook} target="_blank" rel="noopener" class="text-gray-300 hover:text-white transition-colors text-lg">
              Facebook
            </a>
          </li>
          <li>
            <a href={contact.social.linkedin} target="_blank" rel="noopener" class="text-gray-300 hover:text-white transition-colors text-lg">
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Contact Info Section -->
    <div class="border-t border-gray-700 pt-8 mb-8">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h4 class="text-lg font-semibold mb-2">HEISER GROUP</h4>
          <p class="text-gray-300 text-lg">
            {contact.address.street}<br />
            {contact.address.city} {contact.address.state} {contact.address.zip}
          </p>
        </div>
        <div>
          <h4 class="text-lg font-semibold mb-2">Contact</h4>
          <p class="text-gray-300 text-lg">
            O: <a href={contact.phone.href} class="hover:text-white transition-colors">{contact.phone.display}</a>
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-700 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="text-gray-400 text-base flex gap-4">
          <a href="/privacy-policy" class="hover:text-white transition-colors">
            Privacy Policy
          </a>
          <span>|</span>
          <a href="/terms" class="hover:text-white transition-colors">
            Terms of Service
          </a>
        </div>
        <div class="text-gray-400 text-base text-center md:text-right">
          Website by <a href="https://point.dog" target="_blank" rel="noopener" class="text-white hover:text-gray-300 transition-colors">point.dog</a> Web Design + Development
        </div>
      </div>
    </div>
  </div>
</footer>
