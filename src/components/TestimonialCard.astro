---
/**
 * TestimonialCard Component
 * Display a single testimonial quote with author
 *
 * Props:
 * - quote: The testimonial text (required)
 * - author: Name of the person (required)
 * - variant: 'default' | 'featured' - styling variant
 */

interface Props {
  quote: string;
  author: string;
  variant?: 'default' | 'featured';
}

const {
  quote,
  author,
  variant = 'default',
} = Astro.props;
---

{variant === 'featured' ? (
  <div class="text-center px-4 md:px-12">
    <blockquote class="text-2xl md:text-3xl font-heading text-brand-navy leading-relaxed mb-8 italic">
      "{quote}"
    </blockquote>
    <cite class="text-xl text-gray-700 font-semibold not-italic">
      &mdash; {author}
    </cite>
  </div>
) : (
  <div class="bg-white p-8 rounded-xl shadow-lg">
    <p class="text-xl text-gray-700 mb-4 italic">"{quote}"</p>
    <p class="text-brand-orange font-semibold">&mdash; {author}</p>
  </div>
)}
