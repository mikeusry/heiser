---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title = 'The Heiser Group',
  description = 'Professional cleaning services in Chicago area and Lake County Illinois',
  image = 'https://res.cloudinary.com/southland-organics/image/upload/w_1200,h_630,c_fill,g_auto/v1759187283/heiser/heiser/62d6c2be5aaec583c2953984_Cleaning_Services_Lake_County_1.jpg',
  type = 'website',
  noindex = false,
} = Astro.props;

// Build canonical URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://heisergroup.com');

// Full image URL for OG
const ogImageURL = new URL(image, Astro.site || 'https://heisergroup.com');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="The Heiser Group" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Additional SEO -->
    <meta name="geo.region" content="US-IL" />
    <meta name="geo.placename" content="Lake County" />

    <!-- point.dog Pixel -->
    <script is:inline>
      window.pdPixelConfig = {
        brandId: 'heiser',
        endpoint: 'https://pd-pixel-heiser.point-dog-digital.workers.dev/collect',
        formSelectors: '#contact-form, form[action*="contact"], .quote-form',
        servicePatterns: ['/residential-cleaning', '/commercial-cleaning', '/specialty-cleaning', '/realty-cleaning']
      };
    </script>
    <script src="https://cdn.point.dog/pixel/pd-pixel-leadgen.min.js" async></script>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
