---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'The Heiser Group', description = 'Professional cleaning services in Chicago area and Lake County Illinois' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- point.dog Pixel -->
    <script is:inline>
      window.pdPixelConfig = {
        brandId: 'heiser',
        endpoint: 'https://pd-pixel-heiser.point-dog-digital.workers.dev/collect',
        formSelectors: '#contact-form, form[action*="contact"], .quote-form',
        servicePatterns: ['/residential-cleaning', '/commercial-cleaning', '/specialty-cleaning', '/realty-cleaning']
      };
    </script>
    <script src="https://cdn.point.dog/pixel/pd-pixel-leadgen.min.js" async></script>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>