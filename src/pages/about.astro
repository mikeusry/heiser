---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CloudinaryImage from '../components/CloudinaryImage.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CoreValues from '../components/CoreValues.astro';
import CTASection from '../components/CTASection.astro';
import { serviceAreas, serviceAreaGrid } from '../lib/serviceAreas';
import { company, contact } from '../lib/contact';

// AboutPage Schema
const aboutPageSchema = {
	"@context": "https://schema.org",
	"@type": "AboutPage",
	"name": "About The Heiser Group",
	"description": "Learn about The Heiser Group's 45+ year history serving Lake County, IL. Family-owned cleaning company, three generations of excellence.",
	"url": "https://heisergroup.com/about",
	"mainEntity": {
		"@type": "LocalBusiness",
		"@id": "https://heisergroup.com/#localbusiness",
		"name": "The Heiser Group",
		"foundingDate": "1978",
		"description": "Family-owned professional cleaning company serving Lake County, IL since 1978. Three generations of Heiser family leadership delivering exceptional residential and commercial cleaning services.",
		"numberOfEmployees": {
			"@type": "QuantitativeValue",
			"minValue": 10,
			"maxValue": 50
		},
		"areaServed": serviceAreas.cities.map(city => ({
			"@type": "City",
			"name": city
		}))
	}
};

const whyChooseUs = [
	{ title: "Highest-Rated Service", description: "One of the top-rated cleaning services in the Chicago area, trusted by hundreds of satisfied customers.", icon: "check" as const },
	{ title: "Flat-Rate Pricing", description: "Simple, transparent pricing with no hidden fees or surprises. You know exactly what you're paying upfront.", icon: "dollar" as const },
	{ title: "Easy Online Booking", description: "Schedule your cleaning service online at your convenience. It's quick, easy, and hassle-free.", icon: "calendar" as const },
	{ title: "We Provide All Supplies", description: "All cleaning products and supplies are provided by us. Just sit back and relax!", icon: "sparkle" as const },
	{ title: "Experienced Team", description: "Our professional cleaning team is trained, experienced, and dedicated to delivering exceptional results.", icon: "team" as const },
	{ title: "Fully Insured", description: "We're fully insured for your peace of mind and protection.", icon: "shield" as const },
];

const generations = [
	{
		image: "Heiser/heiser/The-Heiser-Group-Our-Story-Grandpa",
		title: "The Founder",
		description: "Established the company in 1978 with a commitment to honesty and integrity."
	},
	{
		image: "Heiser/heiser/The-Heiser-Group-Our-Story-Father",
		title: "Second Generation",
		description: "Built upon the foundation with dedication to quality and service excellence."
	},
	{
		image: "Heiser/heiser/The-Heiser-Group-Our-Story-David",
		title: "David Heiser",
		description: "Third generation leader continuing the family tradition of exceptional cleaning services."
	}
];
---

<BaseLayout title="About The Heiser Group | Family-Owned Cleaning Since 1978 | Lake County IL" description="Learn about The Heiser Group's 45+ year history serving Lake County, IL. Three generations of family ownership, background-checked teams, and a commitment to excellence.">
	<script type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />

	<PageHero
		title="Our History"
		subtitle="Generations of trust, quality, and exceptional service"
		centered
	/>

	<!-- Our Story -->
	<section class="py-20 bg-white">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-12 items-center">
				<div>
					<SectionHeader title="The Heiser Group Story" centered={false} />
					<div class="prose prose-lg max-w-none">
						<p class="text-xl text-gray-700 leading-relaxed mb-6">
							For generations, The Heiser Group has been serving the Chicago area and Lake County Illinois with professional cleaning services that exceed expectations. Our commitment to <strong>honesty</strong>, <strong>integrity</strong>, <strong>quality</strong>, and <strong>service</strong> has made us one of the highest-rated cleaning companies in the region.
						</p>
						<p class="text-xl text-gray-700 leading-relaxed mb-6">
							We understand that your time is valuable, and the last thing you need is to worry about cleaning. That's why we've built our business on providing hassle-free, thorough cleaning services with simple flat-rate pricing and easy online booking.
						</p>
						<p class="text-xl text-gray-700 leading-relaxed">
							From residential homes to commercial offices, from real estate properties to specialty cleaning needs, The Heiser Group has the experience and expertise to deliver outstanding results every single time.
						</p>
					</div>
				</div>
				<div>
					<CloudinaryImage
						publicId="Heiser/heiser/62cc7921cb19c9f729dbc81f_AdobeStock_321262289"
						alt="Professional cleaning team providing exceptional service"
						width={800}
						height={600}
						class="rounded-lg shadow-lg"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Family Tradition -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-12">
				<SectionHeader title="Three Generations of Excellence" />
				<p class="text-xl text-gray-700 leading-relaxed max-w-3xl mx-auto">
					Founded on May 5th, {company.founded}, The Heiser Group is a family-owned and operated business in its third generation of "Heiser". David's grandfather and father believed that any company can clean a building, but going the extra mile can separate a normal janitorial company from a great one.
				</p>
			</div>
			<div class="grid md:grid-cols-3 gap-8">
				{generations.map(gen => (
					<div class="text-center">
						<img
							src={`https://res.cloudinary.com/southland-organics/image/upload/w_400,h_600,c_fill,g_face/${gen.image}.jpg`}
							alt={gen.title}
							width="400"
							height="600"
							class="rounded-lg shadow-lg mb-4 mx-auto"
						/>
						<h3 class="text-2xl font-heading font-bold text-brand-navy mb-2">{gen.title}</h3>
						<p class="text-gray-700">{gen.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Core Values -->
	<CoreValues />

	<!-- Why Choose Us -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader title="Why Choose The Heiser Group" />
			<div class="grid md:grid-cols-2 gap-12">
				{whyChooseUs.map(item => (
					<FeatureCard
						title={item.title}
						description={item.description}
						icon={item.icon}
						iconSize="md"
					/>
				))}
			</div>
		</div>
	</section>

	<!-- Service Area -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<SectionHeader title={`Serving the ${serviceAreas.region}`} />
			<p class="text-xl text-gray-700 leading-relaxed mb-8">
				We proudly serve <strong>{serviceAreas.primary}</strong> and surrounding areas, including:
			</p>
			<div class="grid md:grid-cols-3 gap-4 text-lg text-gray-600">
				{serviceAreaGrid.map(city => (
					<div>{city}</div>
				))}
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<CTASection
		title="Ready to Experience the Difference?"
		subtitle="Join hundreds of satisfied customers who trust The Heiser Group for their cleaning needs."
		buttonText="Get Your Free Quote"
		buttonLink="/contact"
	/>
</BaseLayout>
