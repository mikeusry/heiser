---
// Admin login — SSR (no prerender)
// Handles both GET (show form) and POST (authenticate)

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password')?.toString();
  const adminPassword = import.meta.env.ADMIN_PASSWORD;

  if (password && password === adminPassword) {
    Astro.cookies.set('heiser_admin_token', password, {
      path: '/',
      httpOnly: true,
      sameSite: 'lax',
      secure: import.meta.env.PROD,
      maxAge: 60 * 60 * 24 * 7, // 7 days
    });
    return Astro.redirect('/admin');
  }

  // Wrong password — fall through to render form with error
  Astro.locals.loginError = true;
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Heiser Group</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #fafafa;
      color: #1f2937;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }

    .login-card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      padding: 2.5rem;
      width: 100%;
      max-width: 380px;
    }

    .brand {
      text-align: center;
      margin-bottom: 2rem;
    }

    .brand-name {
      font-size: 1.25rem;
      font-weight: 700;
      color: #1A2B3D;
      letter-spacing: 0.02em;
    }

    .brand-sub {
      font-size: 0.75rem;
      color: #6b7280;
      margin-top: 0.25rem;
    }

    label {
      display: block;
      font-size: 0.8125rem;
      font-weight: 600;
      color: #374151;
      margin-bottom: 0.375rem;
    }

    input[type="password"] {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      font-size: 0.9375rem;
      outline: none;
      font-family: inherit;
      margin-bottom: 1.25rem;
    }

    input[type="password"]:focus {
      border-color: #1A2B3D;
      box-shadow: 0 0 0 3px rgba(26,43,61,0.1);
    }

    button {
      width: 100%;
      padding: 0.75rem;
      background: #1A2B3D;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
    }

    button:hover { background: #16304d; }

    .error {
      background: #fee2e2;
      color: #991b1b;
      padding: 0.625rem 0.875rem;
      border-radius: 6px;
      font-size: 0.8125rem;
      margin-bottom: 1rem;
    }

    .back {
      display: block;
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.8125rem;
      color: #6b7280;
      text-decoration: none;
    }

    .back:hover { color: #1A2B3D; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="brand">
      <div class="brand-name">Nexus Admin</div>
      <div class="brand-sub">Heiser Group</div>
    </div>

    {Astro.locals.loginError && (
      <div class="error">Invalid password. Please try again.</div>
    )}

    <form method="POST">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="Enter admin password" autofocus required />
      <button type="submit">Sign In</button>
    </form>

    <a href="/" class="back">Back to site</a>
  </div>
</body>
</html>
