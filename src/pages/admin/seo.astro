---
// SEO Dashboard — SSR (no prerender)
import AdminLayout from '../../layouts/AdminLayout.astro';
import { fetchSEODashboard } from '../../lib/gsc';
import type { SEODashboardData } from '../../lib/gsc';

let data: SEODashboardData | null = null;
let error: string | null = null;

try {
  data = await fetchSEODashboard({
    GSC_CLIENT_EMAIL: import.meta.env.GSC_CLIENT_EMAIL,
    GSC_PRIVATE_KEY: import.meta.env.GSC_PRIVATE_KEY,
    GSC_SITE_URL: import.meta.env.GSC_SITE_URL,
  });
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to fetch GSC data';
}

function fmtNum(n: number): string {
  return n.toLocaleString('en-US');
}

function fmtPct(n: number): string {
  return (n * 100).toFixed(1) + '%';
}

function fmtPos(n: number): string {
  return n.toFixed(1);
}

function stripDomain(url: string): string {
  try {
    return new URL(url).pathname;
  } catch {
    return url;
  }
}
---

<AdminLayout title="SEO Dashboard" description={data ? `${data.period.start} to ${data.period.end}` : 'Google Search Console data'}>

  {error && (
    <div class="error-banner">
      <strong>Error:</strong> {error}
    </div>
  )}

  {data && (
    <>
      <!-- Metrics cards -->
      <div class="metrics-grid">
        <div class="admin-card metric-card">
          <div class="metric-value">{fmtNum(data.metrics.totalClicks)}</div>
          <div class="metric-label">Total Clicks</div>
        </div>
        <div class="admin-card metric-card">
          <div class="metric-value">{fmtNum(data.metrics.totalImpressions)}</div>
          <div class="metric-label">Total Impressions</div>
        </div>
        <div class="admin-card metric-card">
          <div class="metric-value">{fmtPct(data.metrics.avgCtr)}</div>
          <div class="metric-label">Avg CTR</div>
        </div>
        <div class="admin-card metric-card">
          <div class="metric-value">{fmtPos(data.metrics.avgPosition)}</div>
          <div class="metric-label">Avg Position</div>
        </div>
      </div>

      <!-- Two column: Queries + Pages -->
      <div class="tables-grid">
        <!-- Top Queries -->
        <div class="admin-card">
          <h2 class="table-title">Top Queries</h2>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th class="th-query">Query</th>
                  <th class="th-num">Clicks</th>
                  <th class="th-num">Impr</th>
                  <th class="th-num">CTR</th>
                  <th class="th-num">Pos</th>
                </tr>
              </thead>
              <tbody>
                {data.topQueries.map((q, i) => (
                  <tr>
                    <td class="td-query">
                      <span class="rank">{i + 1}</span>
                      {q.query}
                    </td>
                    <td class="td-num">{fmtNum(q.clicks)}</td>
                    <td class="td-num">{fmtNum(q.impressions)}</td>
                    <td class="td-num">{fmtPct(q.ctr)}</td>
                    <td class="td-num">
                      <span class={`pos-badge ${q.position <= 3 ? 'pos-top' : q.position <= 10 ? 'pos-page1' : q.position <= 20 ? 'pos-page2' : 'pos-deep'}`}>
                        {fmtPos(q.position)}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Top Pages -->
        <div class="admin-card">
          <h2 class="table-title">Top Pages</h2>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th class="th-query">Page</th>
                  <th class="th-num">Clicks</th>
                  <th class="th-num">Impr</th>
                  <th class="th-num">CTR</th>
                  <th class="th-num">Pos</th>
                </tr>
              </thead>
              <tbody>
                {data.topPages.map((p) => (
                  <tr>
                    <td class="td-page">
                      <a href={p.page} target="_blank" rel="noopener">{stripDomain(p.page)}</a>
                    </td>
                    <td class="td-num">{fmtNum(p.clicks)}</td>
                    <td class="td-num">{fmtNum(p.impressions)}</td>
                    <td class="td-num">{fmtPct(p.ctr)}</td>
                    <td class="td-num">
                      <span class={`pos-badge ${p.position <= 3 ? 'pos-top' : p.position <= 10 ? 'pos-page1' : p.position <= 20 ? 'pos-page2' : 'pos-deep'}`}>
                        {fmtPos(p.position)}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="footer-meta">
        Data from Google Search Console &middot; {data.period.start} to {data.period.end} &middot; Fetched {new Date(data.fetchedAt).toLocaleString('en-US')}
      </div>
    </>
  )}
</AdminLayout>

<style>
  .error-banner {
    background: var(--error-light);
    color: var(--error);
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  /* Metric cards */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .metric-card {
    text-align: center;
    padding: 1.25rem 1rem;
  }

  .metric-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--admin-primary);
    line-height: 1;
    margin-bottom: 0.375rem;
  }

  .metric-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  /* Tables layout */
  .tables-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .table-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }

  th {
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: 0.5rem 0.625rem;
    border-bottom: 2px solid var(--border);
  }

  .th-num {
    text-align: right;
    white-space: nowrap;
  }

  td {
    padding: 0.5rem 0.625rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .td-num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .td-query {
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .td-page {
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .td-page a {
    color: var(--admin-accent);
    text-decoration: none;
  }

  .td-page a:hover {
    text-decoration: underline;
  }

  .rank {
    display: inline-block;
    width: 1.5rem;
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  tr:hover {
    background: var(--surface-alt);
  }

  /* Position badges */
  .pos-badge {
    display: inline-block;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pos-top {
    background: var(--success-light);
    color: #166534;
  }

  .pos-page1 {
    background: #dbeafe;
    color: #1e40af;
  }

  .pos-page2 {
    background: var(--warning-light);
    color: #92400e;
  }

  .pos-deep {
    background: var(--surface-alt);
    color: var(--text-muted);
  }

  .footer-meta {
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-muted);
    padding-top: 0.5rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .tables-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .metrics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
