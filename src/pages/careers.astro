---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CTASection from '../components/CTASection.astro';

// JobPosting Schema
const jobPostingSchema = {
	"@context": "https://schema.org",
	"@type": "JobPosting",
	"title": "Professional House Cleaner",
	"description": "Join The Heiser Group team as a professional house cleaner. We're looking for trustworthy, detail-oriented individuals to provide excellent residential and commercial cleaning services in Lake County, IL. No experience necessary - full training provided. Competitive pay, flexible scheduling, and a great team environment.",
	"datePosted": "2024-12-01",
	"validThrough": "2025-12-31",
	"employmentType": ["FULL_TIME", "PART_TIME"],
	"hiringOrganization": {
		"@type": "LocalBusiness",
		"@id": "https://heisergroup.com/#localbusiness",
		"name": "The Heiser Group",
		"sameAs": "https://heisergroup.com",
		"logo": "https://heisergroup.com/logo.png"
	},
	"jobLocation": {
		"@type": "Place",
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Lake County",
			"addressRegion": "IL",
			"addressCountry": "US"
		}
	},
	"baseSalary": {
		"@type": "MonetaryAmount",
		"currency": "USD",
		"value": {
			"@type": "QuantitativeValue",
			"minValue": 15,
			"maxValue": 22,
			"unitText": "HOUR"
		}
	},
	"jobBenefits": "Flexible scheduling, competitive pay, training provided, team environment",
	"qualifications": "Reliable transportation, ability to pass background check, detail-oriented, positive attitude",
	"responsibilities": "Residential and commercial cleaning, following cleaning checklists, maintaining high quality standards",
	"skills": "Attention to detail, time management, customer service"
};

const benefits = [
	{ title: "Great Team Environment", description: "Work with a supportive team that values your contribution and helps you succeed.", icon: "team" as const },
	{ title: "Competitive Compensation", description: "We offer competitive wages and opportunities for advancement.", icon: "dollar" as const },
	{ title: "Flexible Scheduling", description: "We work with you to create a schedule that fits your lifestyle.", icon: "calendar" as const },
	{ title: "Training & Support", description: "Full training provided. No experience necessary!", icon: "shield" as const },
];

const requirements = [
	"Trustworthy individuals with a strong work ethic",
	"Detail-oriented and takes pride in their work",
	"Cooperates well with others and maintains a positive attitude",
	"Reliable transportation",
	"Ability to pass a background check",
];
---

<BaseLayout title="Cleaning Jobs Lake County IL | Careers at The Heiser Group" description="Now hiring professional house cleaners in Lake County, IL. Competitive pay $15-22/hr, flexible scheduling, full training provided. Join a family-owned company with 45+ years of excellence.">
	<script type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)} />

	<PageHero
		title="Join Our Team"
		subtitle="Looking for trustworthy employees who take pride in providing excellent cleaning service"
		centered
	/>

	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="Why Work With Us?" centered={false} />
			<div class="space-y-8">
				{benefits.map(benefit => (
					<FeatureCard
						title={benefit.title}
						description={benefit.description}
						icon={benefit.icon}
						iconSize="lg"
					/>
				))}
			</div>
		</div>
	</section>

	<section class="py-20 bg-gray-50">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="What We're Looking For" centered={false} />
			<div class="bg-white p-8 rounded-2xl shadow-lg">
				<ul class="space-y-4 text-lg text-gray-700">
					{requirements.map(req => (
						<li class="flex items-start gap-3">
							<svg class="w-6 h-6 text-brand-orange flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
							</svg>
							<span>{req}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<CTASection
		title="Ready to Join Our Team?"
		subtitle="Contact us today to learn more about current job openings and start your career with The Heiser Group."
		buttonText="Apply Now"
		buttonLink="/contact"
	/>
</BaseLayout>
