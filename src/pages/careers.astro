---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';

// JobPosting Schema
const jobPostingSchema = {
	"@context": "https://schema.org",
	"@type": "JobPosting",
	"title": "Professional House Cleaner",
	"description": "Join The Heiser Group team as a professional house cleaner. We're looking for trustworthy, detail-oriented individuals to provide excellent residential and commercial cleaning services in Lake County, IL. No experience necessary - full training provided. Competitive pay, flexible scheduling, and a great team environment.",
	"datePosted": "2024-12-01",
	"validThrough": "2025-12-31",
	"employmentType": ["FULL_TIME", "PART_TIME"],
	"hiringOrganization": {
		"@type": "LocalBusiness",
		"@id": "https://heisergroup.com/#localbusiness",
		"name": "The Heiser Group",
		"sameAs": "https://heisergroup.com",
		"logo": "https://heisergroup.com/logo.png"
	},
	"jobLocation": {
		"@type": "Place",
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Lake County",
			"addressRegion": "IL",
			"addressCountry": "US"
		}
	},
	"baseSalary": {
		"@type": "MonetaryAmount",
		"currency": "USD",
		"value": {
			"@type": "QuantitativeValue",
			"minValue": 15,
			"maxValue": 22,
			"unitText": "HOUR"
		}
	},
	"jobBenefits": "Flexible scheduling, competitive pay, training provided, team environment",
	"qualifications": "Reliable transportation, ability to pass background check, detail-oriented, positive attitude",
	"responsibilities": "Residential and commercial cleaning, following cleaning checklists, maintaining high quality standards",
	"skills": "Attention to detail, time management, customer service"
};

const benefits = [
	{ title: "Great Team Environment", description: "Work with a supportive team that values your contribution and helps you succeed.", icon: "team" as const },
	{ title: "Competitive Compensation", description: "We offer competitive wages and opportunities for advancement.", icon: "dollar" as const },
	{ title: "Flexible Scheduling", description: "We work with you to create a schedule that fits your lifestyle.", icon: "calendar" as const },
	{ title: "Training & Support", description: "Full training provided. No experience necessary!", icon: "shield" as const },
];

const requirements = [
	"Trustworthy individuals with a strong work ethic",
	"Detail-oriented and takes pride in their work",
	"Cooperates well with others and maintains a positive attitude",
	"Reliable transportation",
	"Ability to pass a background check",
];

const positionOptions = [
	{ value: "scrub-crew-lead", label: "Scrub Crew Lead ($25–$32/hr)" },
	{ value: "part-time-janitor", label: "Part-Time Janitor Position" },
	{ value: "full-time-janitor", label: "Full-Time Janitor Position" },
	{ value: "day-porter", label: "Day Porter Position" },
	{ value: "residential-cleaning", label: "Residential Cleaning Crew" },
];
---

<BaseLayout title="Cleaning Jobs Lake County IL | Careers at The Heiser Group" description="Now hiring professional house cleaners in Lake County, IL. Competitive pay $15-22/hr, flexible scheduling, full training provided. Join a family-owned company with 45+ years of excellence.">
	<script type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)} />

	<PageHero
		title="Join Our Team"
		subtitle="Looking for trustworthy employees who take pride in providing excellent cleaning service"
		centered
	/>

	<!-- Open Positions -->
	<section class="py-16 bg-brand-cream">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="Open Positions" centered={false} />
			<div class="space-y-4 mt-8">
				<a
					href="/careers/scrub-crew-lead"
					class="block bg-white p-6 md:p-8 rounded-2xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all"
				>
					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
						<div>
							<h3 class="text-2xl font-heading font-bold text-brand-navy mb-1">Scrub Crew Lead</h3>
							<p class="text-gray-600">Lead specialty cleaning projects — strip &amp; wax, post-construction, deep clean, floor care.</p>
							<div class="flex flex-wrap gap-3 mt-3 text-sm text-gray-500">
								<span class="bg-gray-100 px-3 py-1 rounded-full">Full-time</span>
								<span class="bg-gray-100 px-3 py-1 rounded-full">Lake County, IL</span>
								<span class="bg-gray-100 px-3 py-1 rounded-full">Vehicle provided</span>
							</div>
						</div>
						<div class="flex items-center gap-2">
							<div class="text-right">
								<p class="text-2xl font-bold text-brand-orange">$25–$32</p>
								<p class="text-xs text-gray-500">per hour</p>
							</div>
							<svg class="w-6 h-6 text-brand-orange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
							</svg>
						</div>
					</div>
				</a>
			</div>
		</div>
	</section>

	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="Why Work With Us?" centered={false} />
			<div class="space-y-8">
				{benefits.map(benefit => (
					<FeatureCard
						title={benefit.title}
						description={benefit.description}
						icon={benefit.icon}
						iconSize="lg"
					/>
				))}
			</div>
		</div>
	</section>

	<section class="py-20 bg-gray-50">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="What We're Looking For" centered={false} />
			<div class="bg-white p-8 rounded-2xl shadow-lg">
				<ul class="space-y-4 text-lg text-gray-700">
					{requirements.map(req => (
						<li class="flex items-start gap-3">
							<svg class="w-6 h-6 text-brand-orange flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
							</svg>
							<span>{req}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<!-- Application Form Section -->
	<section id="apply" class="py-20 bg-white">
		<div class="max-w-2xl mx-auto px-6">
			<SectionHeader
				title="Apply Now"
				subtitle="Ready to join our team? Fill out the form below and we'll be in touch."
			/>

			<div class="bg-gray-50 p-8 rounded-2xl shadow-lg">
				<form id="careers-form" action="https://heiser-contact-form.point-dog-digital.workers.dev" method="POST" class="space-y-6">
					<input type="hidden" name="form_type" value="careers" />
					<!-- Honeypot field - hidden from users, catches bots -->
					<div class="hidden" aria-hidden="true">
						<label for="website">Website</label>
						<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
					</div>

					<div>
						<label for="name" class="block text-sm font-semibold text-gray-700 mb-2">Name *</label>
						<input
							type="text"
							id="name"
							name="name"
							required
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-orange focus:border-transparent"
						/>
					</div>

					<div>
						<label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-orange focus:border-transparent"
						/>
					</div>

					<div>
						<label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">Phone Number *</label>
						<input
							type="tel"
							id="phone"
							name="phone"
							required
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-orange focus:border-transparent"
						/>
					</div>

					<div>
						<label for="position" class="block text-sm font-semibold text-gray-700 mb-2">Desired Position *</label>
						<select
							id="position"
							name="position"
							required
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-orange focus:border-transparent"
						>
							<option value="">Select a position</option>
							{positionOptions.map(option => (
								<option value={option.value}>{option.label}</option>
							))}
						</select>
					</div>

					<div>
						<label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Message</label>
						<textarea
							id="message"
							name="message"
							rows="4"
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand-orange focus:border-transparent"
							placeholder="Tell us a bit about yourself..."
						></textarea>
					</div>

					<button
						type="submit"
						class="w-full bg-brand-orange text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-brand-orange-dark transition-all duration-300 hover:shadow-lg"
					>
						Submit Application
					</button>

					<div id="form-message" class="hidden p-4 rounded-lg text-center"></div>
				</form>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	const form = document.getElementById('careers-form') as HTMLFormElement;
	const formMessage = document.getElementById('form-message');

	// Pre-select position from ?position= query param (e.g. linked from /careers/scrub-crew-lead)
	const params = new URLSearchParams(window.location.search);
	const presetPosition = params.get('position');
	if (presetPosition) {
		const positionSelect = document.getElementById('position') as HTMLSelectElement | null;
		if (positionSelect && [...positionSelect.options].some(o => o.value === presetPosition)) {
			positionSelect.value = presetPosition;
		}
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		const formData = new FormData(form);

		// Show loading state
		const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
		const originalText = submitButton.textContent;
		submitButton.textContent = 'Submitting...';
		submitButton.disabled = true;

		try {
			const response = await fetch(form.action, {
				method: 'POST',
				body: formData,
				headers: {
					'Accept': 'application/json'
				}
			});

			const data = await response.json();

			if (response.ok && data.success) {
				// Show success message
				if (formMessage) {
					formMessage.textContent = 'Thank you for your application! We\'ll be in touch soon.';
					formMessage.className = 'p-4 rounded-lg text-center bg-green-100 text-green-800';
					formMessage.classList.remove('hidden');
				}
				form.reset();
			} else {
				throw new Error(data.error || 'Form submission failed');
			}

		} catch (error) {
			// Error message
			if (formMessage) {
				formMessage.textContent = 'Something went wrong. Please try again or call us directly.';
				formMessage.className = 'p-4 rounded-lg text-center bg-red-100 text-red-800';
				formMessage.classList.remove('hidden');
			}
		} finally {
			// Reset button
			submitButton.textContent = originalText;
			submitButton.disabled = false;

			// Hide message after 5 seconds
			setTimeout(() => {
				formMessage?.classList.add('hidden');
			}, 5000);
		}
	});
</script>
