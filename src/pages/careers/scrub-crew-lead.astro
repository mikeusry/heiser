---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { contact } from '../../lib/contact';

const title = "Scrub Crew Lead — $25–$32/hr | Careers | The Heiser Group";
const description = "Hiring a Scrub Crew Lead to run specialty cleaning projects in Lake County, IL. Strip & wax, post-construction, deep clean, floor care. $25–$32/hr based on experience. Company vehicle provided.";

const jobPostingSchema = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": "Scrub Crew Lead",
  "description": "The Scrub Crew Lead is responsible for performing specialty cleaning projects from start to finish. This role ensures that all work is completed on schedule, within scope, and to company quality standards. The Scrub Crew Lead brings hands-on specialty cleaning experience, manages crews and resources across multiple job sites, communicates with clients and internal teams, and safely operates a company vehicle to travel between projects as needed.",
  "datePosted": "2026-04-28",
  "validThrough": "2026-12-31",
  "employmentType": "FULL_TIME",
  "hiringOrganization": {
    "@type": "LocalBusiness",
    "@id": "https://heisergroup.com/#localbusiness",
    "name": "The Heiser Group",
    "sameAs": "https://heisergroup.com",
    "logo": "https://res.cloudinary.com/southland-organics/image/upload/w_600,q_auto,f_auto/Heiser/heiser/heiser-logo"
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Lake County",
      "addressRegion": "IL",
      "addressCountry": "US"
    }
  },
  "baseSalary": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": {
      "@type": "QuantitativeValue",
      "minValue": 25,
      "maxValue": 32,
      "unitText": "HOUR"
    }
  },
  "directApply": true,
  "applicantLocationRequirements": {
    "@type": "Country",
    "name": "US"
  },
  "url": "https://heisergroup.com/careers/scrub-crew-lead",
  "jobBenefits": "Competitive pay $25–$32/hr based on experience, overtime eligibility, company vehicle provided during work hours, opportunities for advancement within operations or management",
  "qualifications": "Strong understanding of specialty cleaning processes and equipment. Proven ability to manage multiple projects. Ability to keep equipment maintained and clean. Valid driver's license with clean driving record. Ability to lift up to 50 lbs.",
  "responsibilities": "Perform specialty cleaning services (post-construction, deep cleaning, move-in/out, floor care, biohazard). Manage projects from start to finish. Drive company vehicle between job sites. Communicate with clients. Conduct safety checks. Track labor hours and complete documentation.",
  "skills": "Specialty cleaning, floor machines, extractors, pressure washers, project management, client communication"
};

const responsibilities = [
  {
    heading: "Hands-On Specialty Cleaning",
    items: [
      "Post-construction cleaning",
      "Deep commercial and residential cleaning",
      "Move-in / move-out cleaning",
      "Floor care — strip & wax, buffing, carpet cleaning, tile & grout",
      "Biohazard, hoarding, or other specialty services (if applicable)",
      "Use cleaning chemicals, tools, and equipment safely and effectively",
      "Ensure all work meets company quality standards and client expectations",
    ],
  },
  {
    heading: "Project Planning & Oversight",
    items: [
      "Manage specialty cleaning projects from initial assignment through completion",
      "Review work orders, scopes of work, and client requirements",
      "Ensure projects are completed on time and within expected labor and cost guidelines",
    ],
  },
  {
    heading: "Hands-On Specialty Cleaning Knowledge",
    items: [
      "Apply practical experience in specialty cleaning to troubleshoot issues",
      "Ensure proper use of equipment, chemicals, and specialty tools",
      "Maintain company standards across all specialty services (post-construction, deep cleaning, floor care, etc.)",
    ],
  },
  {
    heading: "Transportation & Logistics",
    items: [
      "Safely drive a company vehicle between multiple job sites",
      "Transport cleaning equipment, tools, and supplies as needed",
      "Ensure vehicle is kept clean, organized, and properly maintained",
      "Report maintenance needs or vehicle concerns promptly",
    ],
  },
  {
    heading: "Client Communication & Customer Service",
    items: [
      "Serve as a primary point of contact for clients during active projects",
      "Communicate project updates, changes, or challenges to Supervisor",
      "Ensure customer satisfaction and resolve issues in a professional manner",
    ],
  },
  {
    heading: "Safety & Compliance",
    items: [
      "Conduct job site safety checks and address hazards immediately",
    ],
  },
  {
    heading: "Reporting & Documentation",
    items: [
      "Track project labor hours",
      "Complete job reports, checklists, and required documentation",
      "Communicate project outcomes, issues, and recommendations to leadership",
    ],
  },
];

const qualifications = [
  "Strong understanding of specialty cleaning processes and equipment",
  "Proven ability to manage multiple projects",
  "Being able to keep equipment maintained and clean",
];

const requirements = [
  "Valid driver's license with a clean driving record",
  "Ability to drive a company vehicle between job sites",
  "Ability to lift up to 50 lbs and work in physically demanding environments as needed",
  "Reliable attendance and flexibility in scheduling",
  "Ability to pass background check and drug screening (if required)",
];

const schedule = [
  "Full-time position with variable hours based on project demands",
  "May include early mornings, evenings, weekends, or emergency projects",
  "Work performed across commercial, residential, and industrial job sites",
];

const preferred = [
  "Experience with floor machines, extractors, pressure washers, or specialty cleaning equipment",
  "Bilingual (English / Spanish) a plus",
];

const compensation = [
  "Competitive pay based on experience ($25 – $32 per hour)",
  "Overtime eligibility (if applicable)",
  "Company vehicle provided during work hours",
  "Opportunities for advancement within operations or management",
];
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jobPostingSchema)} />

  <PageHero
    title="Scrub Crew Lead"
    subtitle="$25–$32 per hour, based on experience · Full-time · Lake County, IL"
    centered
  />

  <!-- Position Summary -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <SectionHeader title="The Position" centered={false} />
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>
          The Scrub Crew Lead is responsible for performing specialty cleaning projects from start to finish.
          This role ensures that all work is completed on schedule, within scope, and to company quality standards.
        </p>
        <p>
          The Scrub Crew Lead brings hands-on specialty cleaning experience, manages crews and resources across
          multiple job sites, communicates with clients and internal teams, and safely operates a company vehicle
          to travel between projects as needed.
        </p>
      </div>

      <!-- Quick Facts -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-10">
        <div class="bg-brand-cream p-6 rounded-lg text-center">
          <p class="text-3xl font-bold text-brand-orange">$25–$32</p>
          <p class="text-sm text-gray-600 mt-1">Per hour</p>
        </div>
        <div class="bg-brand-cream p-6 rounded-lg text-center">
          <p class="text-3xl font-bold text-brand-orange">Full-Time</p>
          <p class="text-sm text-gray-600 mt-1">Variable hours</p>
        </div>
        <div class="bg-brand-cream p-6 rounded-lg text-center">
          <p class="text-3xl font-bold text-brand-orange">Lake County</p>
          <p class="text-sm text-gray-600 mt-1">Illinois</p>
        </div>
        <div class="bg-brand-cream p-6 rounded-lg text-center">
          <p class="text-3xl font-bold text-brand-orange">Vehicle</p>
          <p class="text-sm text-gray-600 mt-1">Provided on-shift</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Responsibilities -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6">
      <SectionHeader title="Key Responsibilities" centered={false} />
      <div class="space-y-8 mt-10">
        {responsibilities.map(group => (
          <div class="bg-white p-8 rounded-2xl shadow-lg">
            <h3 class="text-xl font-heading font-bold text-brand-navy mb-4">{group.heading}</h3>
            <ul class="space-y-3 text-gray-700">
              {group.items.map(item => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-orange flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Qualifications & Requirements -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Qualifications -->
        <div>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-navy mb-6">Qualifications &amp; Experience</h2>
          <ul class="space-y-3 text-gray-700">
            {qualifications.map(item => (
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-brand-orange flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Requirements -->
        <div>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-navy mb-6">Requirements</h2>
          <ul class="space-y-3 text-gray-700">
            {requirements.map(item => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-navy flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule & Preferred -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-lg">
          <h3 class="text-xl font-heading font-bold text-brand-navy mb-4">Schedule &amp; Work Environment</h3>
          <ul class="space-y-3 text-gray-700">
            {schedule.map(item => (
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-orange flex-shrink-0 mt-2.5"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-lg">
          <h3 class="text-xl font-heading font-bold text-brand-navy mb-4">Preferred Skills <span class="text-sm font-normal text-gray-500">(Nice to have)</span></h3>
          <ul class="space-y-3 text-gray-700">
            {preferred.map(item => (
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-orange flex-shrink-0 mt-2.5"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Compensation & Benefits -->
  <section class="py-20 bg-brand-navy text-white">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-8">Compensation &amp; Benefits</h2>
      <ul class="space-y-4 text-lg">
        {compensation.map(item => (
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-brand-orange flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Apply CTA -->
  <section class="py-20 bg-brand-cream">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-4">
        Ready to Apply?
      </h2>
      <p class="text-xl text-gray-600 mb-8">
        Fill out our quick application or call us directly. We'll get back to you within one business day.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="/careers?position=scrub-crew-lead#apply"
          class="inline-flex items-center gap-2 bg-brand-orange text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-brand-orange-dark transition-all"
        >
          Apply Now
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href={contact.phone.href}
          class="inline-flex items-center gap-2 bg-white text-brand-navy px-8 py-4 rounded-lg font-semibold text-lg border-2 border-brand-navy hover:bg-brand-navy hover:text-white transition-all"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call {contact.phone.display}
        </a>
      </div>
    </div>
  </section>

  <!-- Back link -->
  <section class="py-12 bg-gray-100">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-gray-500">
        <a href="/careers" class="text-brand-orange hover:underline">← Back to Careers</a>
      </p>
    </div>
  </section>
</BaseLayout>
