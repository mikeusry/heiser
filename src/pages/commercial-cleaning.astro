---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CTASection from '../components/CTASection.astro';
import { contact, company } from '../lib/contact';

const title = "Commercial Cleaning Service Lake County IL | The Heiser Group";
const description = "Professional commercial cleaning and janitorial services for Lake County IL businesses. Office cleaning, medical facilities, flexible scheduling. Month-to-month, no contracts.";

const partnerBenefits = [
	{
		title: "Proactive Communication",
		description: "We tell you about issues before you notice them. Low supplies, equipment problems, schedule changes—you'll know first, not last.",
		icon: "sparkle" as const
	},
	{
		title: "One Person to Call",
		description: "No call trees. No ticket systems. When you have an issue, you call your account manager directly. They know your building.",
		icon: "check" as const
	},
	{
		title: "Flexible Scheduling",
		description: "Early morning? After hours? Weekends before a big client meeting? We work around your business, not the other way around.",
		icon: "calendar" as const
	},
	{
		title: "30-Day Flexibility",
		description: "Our service agreement includes a simple 30-day cancellation clause. We're confident you'll stay because we deliver—not because you're locked in.",
		icon: "star" as const
	}
];

const dailyServices = [
	"Trash removal and recycling",
	"Restroom sanitization and restocking",
	"Break room and kitchen cleaning",
	"Desk and surface dusting",
	"Floor vacuuming and mopping"
];

const periodicServices = [
	"Carpet cleaning and extraction",
	"Hard floor stripping and waxing",
	"Window washing (interior and exterior)",
	"High dusting and vent cleaning",
	"Upholstery cleaning"
];

const specialtyServices = [
	"Medical office cleaning (OSHA-compliant)",
	"Post-construction cleanup",
	"Move-in/move-out cleaning",
	"Event prep and cleanup"
];

const industries = [
	{
		title: "Professional Offices",
		description: "Law firms, accounting offices, consulting firms. We understand client-facing spaces need to look sharp."
	},
	{
		title: "Medical & Dental Offices",
		description: "OSHA-compliant cleaning protocols. Proper handling of biohazard areas. We know the requirements."
	},
	{
		title: "Small Manufacturing",
		description: "Office areas, break rooms, and common spaces. We keep your front-of-house professional."
	},
	{
		title: "Retail & Showrooms",
		description: "Floor care, display cleaning, and customer areas that make the right impression."
	}
];

const whyHeiser = [
	{
		title: "45+ Years in Lake County",
		description: "We're not a national franchise learning your area. We've been cleaning Lake County businesses since 1979."
	},
	{
		title: "Background-Checked & Insured",
		description: "Every cleaner passes a thorough background check. Fully bonded and insured. Your property and people are protected."
	},
	{
		title: "Consistent Teams",
		description: "The same crew comes to your building. They know your space, your preferences, your alarm codes."
	},
	{
		title: "Quality Inspections",
		description: "Random quality checks and supervisor walkthroughs. We catch problems before you do."
	}
];

const steps = [
	{
		number: 1,
		title: "Quick Walkthrough",
		description: "We'll visit your space and understand your needs. What's working? What's not? What are your priorities?"
	},
	{
		number: 2,
		title: "Custom Proposal",
		description: "Within 48 hours, you get a detailed scope of work and flat-rate pricing. No surprises, no hidden fees."
	},
	{
		number: 3,
		title: "Trial Period",
		description: "Start with a trial period. See how we perform before committing to an ongoing schedule."
	},
	{
		number: 4,
		title: "Ongoing Partnership",
		description: "Regular check-ins, quality reviews, and open communication. We're partners in keeping your space professional."
	}
];

const pricing = [
	{
		size: "Small office (1,000-3,000 sq ft)",
		range: "$300-$600/month"
	},
	{
		size: "Medium office (3,000-7,000 sq ft)",
		range: "$600-$1,200/month"
	},
	{
		size: "Large office (7,000-15,000 sq ft)",
		range: "$1,200-$2,500/month"
	}
];

const faqs = [
	{
		question: "Can you clean outside of business hours?",
		answer: "Yes. Most of our commercial clients prefer early morning or after-hours cleaning. We work around your schedule."
	},
	{
		question: "How do you handle secure areas?",
		answer: "We work with your security protocols. Badge access, alarm codes, restricted areas—we've worked with all types of security requirements."
	},
	{
		question: "What happens if our needs change?",
		answer: "We're flexible. Need to add a day? Scale back temporarily? Increase scope before a big event? Just tell us."
	},
	{
		question: "Do you have experience with offices our size?",
		answer: "We serve offices from 5 employees to 100+. Whether you're a small professional practice or a larger corporate office, we scale to fit."
	},
	{
		question: "What's included vs. extra?",
		answer: "Your proposal spells out exactly what's included. Extras like carpet cleaning or window washing can be added as-needed or on a schedule."
	},
	{
		question: "Do you provide supplies?",
		answer: "We can provide all cleaning supplies and restock restroom supplies, or work with your preferred products. Your choice."
	},
	{
		question: "What if we have a tight budget?",
		answer: "We'll work with you. We can adjust frequency, focus on high-traffic areas, or phase in services over time. Quality cleaning doesn't have to break the budget—let's find what works for your situation."
	}
];

// Schema markup
const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer
		}
	}))
};

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"name": "Commercial Cleaning Service",
	"description": "Professional commercial cleaning and janitorial services for Lake County IL businesses. Office cleaning, medical facilities, flexible scheduling.",
	"provider": {
		"@type": "LocalBusiness",
		"name": company.name,
		"telephone": contact.phone.display,
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Grayslake",
			"addressRegion": "IL",
			"addressCountry": "US"
		}
	},
	"areaServed": [
		{ "@type": "County", "name": "Lake County", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Grayslake", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Libertyville", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Vernon Hills", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Mundelein", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Waukegan", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Highland Park", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Lake Forest", "containedIn": "Illinois" }
	],
	"serviceType": ["Commercial Cleaning", "Office Cleaning", "Janitorial Services", "Medical Office Cleaning"]
};
---

<BaseLayout title={title} description={description}>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

	<PageHero
		eyebrow="COMMERCIAL CLEANING SERVICE"
		title="Office Cleaning That Just Gets Handled"
		subtitle="A cleaning partner, not another vendor to manage. Professional commercial cleaning for Lake County businesses."
	/>

	<!-- The Problem Section -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-6">
				You Didn't Sign Up to Be a Cleaning Expert
			</h2>
			<div class="space-y-4 text-lg text-gray-700">
				<p>
					You've got enough on your plate. Facilities, vendors, employees, budgets—and somewhere in there, you're supposed to keep the office clean too.
				</p>
				<p>
					You've dealt with the flaky vendors. The ones who miss spots, show up late, or just stop showing up. The ones where every issue becomes a phone tag marathon.
				</p>
				<p>
					When the cleaning falls short, you hear about it. From employees. From leadership. It reflects on you.
				</p>
				<p class="font-semibold text-brand-navy">
					You need a cleaning partner who handles it—so you don't have to think about it.
				</p>
			</div>
		</div>
	</section>

	<!-- Partner Benefits Section -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader
				title="A Cleaning Partner, Not Just a Vendor"
				subtitle="Here's what 'handled' actually looks like"
			/>
			<div class="grid md:grid-cols-2 gap-8">
				{partnerBenefits.map(benefit => (
					<div class="bg-white p-8 rounded-xl shadow-lg">
						<FeatureCard
							title={benefit.title}
							description={benefit.description}
							icon={benefit.icon}
							iconSize="lg"
						/>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section class="py-20 bg-white">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader title="What's Included" />
			<div class="grid md:grid-cols-3 gap-8">
				<div class="bg-gray-50 p-8 rounded-xl">
					<h3 class="text-2xl font-heading font-bold text-brand-navy mb-4">Daily/Nightly Cleaning</h3>
					<ul class="space-y-3">
						{dailyServices.map(item => (
							<li class="flex items-start gap-3">
								<svg class="w-5 h-5 text-brand-orange mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
								</svg>
								<span class="text-gray-700">{item}</span>
							</li>
						))}
					</ul>
				</div>
				<div class="bg-gray-50 p-8 rounded-xl">
					<h3 class="text-2xl font-heading font-bold text-brand-navy mb-4">Periodic Deep Cleaning</h3>
					<ul class="space-y-3">
						{periodicServices.map(item => (
							<li class="flex items-start gap-3">
								<svg class="w-5 h-5 text-brand-orange mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
								</svg>
								<span class="text-gray-700">{item}</span>
							</li>
						))}
					</ul>
				</div>
				<div class="bg-gray-50 p-8 rounded-xl">
					<h3 class="text-2xl font-heading font-bold text-brand-navy mb-4">Specialty Services</h3>
					<ul class="space-y-3">
						{specialtyServices.map(item => (
							<li class="flex items-start gap-3">
								<svg class="w-5 h-5 text-brand-orange mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
								</svg>
								<span class="text-gray-700">{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Industries Section -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader
				title="Industries We Serve"
				subtitle="Experience across business types"
			/>
			<div class="grid md:grid-cols-2 gap-8">
				{industries.map(industry => (
					<div class="bg-white p-8 rounded-xl shadow-md">
						<h3 class="text-xl font-heading font-bold text-brand-navy mb-2">{industry.title}</h3>
						<p class="text-gray-600">{industry.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Why Heiser Section -->
	<section class="py-20 bg-brand-navy text-white">
		<div class="max-w-6xl mx-auto px-6">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
					Why Lake County Businesses Choose Heiser
				</h2>
			</div>
			<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
				{whyHeiser.map(item => (
					<div class="text-center">
						<div class="w-16 h-16 bg-brand-orange rounded-full flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
							</svg>
						</div>
						<h3 class="text-xl font-heading font-bold mb-2">{item.title}</h3>
						<p class="text-gray-300">{item.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Pricing Section -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader
				title="What Does Commercial Cleaning Cost?"
				subtitle="Every building is different. We quote based on square footage, cleaning frequency, scope of services, and scheduling requirements."
			/>
			<div class="bg-gray-50 rounded-xl p-8">
				<h3 class="text-xl font-heading font-bold text-brand-navy mb-6">Typical ranges for Lake County offices:</h3>
				<div class="space-y-4">
					{pricing.map(tier => (
						<div class="flex justify-between items-center py-3 border-b border-gray-200 last:border-0">
							<span class="text-gray-700">{tier.size}</span>
							<span class="font-semibold text-brand-navy">{tier.range}</span>
						</div>
					))}
				</div>
				<p class="mt-6 text-sm text-gray-600 italic">
					Pricing varies based on scope and frequency. Request a walkthrough for accurate pricing.
				</p>
				<div class="mt-6 p-4 bg-brand-cream rounded-lg">
					<p class="font-semibold text-brand-navy">
						30-Day Flexibility — We're confident you'll stay because we deliver, not because you're locked in.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- How It Works -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader title="Getting Started Is Simple" />
			<div class="grid md:grid-cols-4 gap-8">
				{steps.map(step => (
					<div class="text-center">
						<div class="w-12 h-12 bg-brand-orange text-white rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">
							{step.number}
						</div>
						<h3 class="text-xl font-heading font-bold text-brand-navy mb-2">{step.title}</h3>
						<p class="text-gray-600">{step.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="Common Questions About Commercial Cleaning" />
			<div class="space-y-6">
				{faqs.map(faq => (
					<div class="border-b border-gray-200 pb-6">
						<h3 class="text-xl font-heading font-bold text-brand-navy mb-2">{faq.question}</h3>
						<p class="text-gray-600">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Commercial Testimonial Section -->
	<section class="py-16 bg-gray-50">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<blockquote class="text-2xl md:text-3xl font-heading italic text-brand-navy leading-relaxed mb-6">
				"After major remodeling and renovation in our building, it was a disaster. David came in and assessed the situation and sent his two best guys. In one evening, they cleaned the inside of the building completely."
			</blockquote>
			<cite class="block text-lg font-semibold text-gray-700 not-italic">
				— Tom Strossner, Lake County Business Owner
			</cite>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-4">
				Ready for Cleaning That Just Gets Handled?
			</h2>
			<p class="text-xl text-gray-600 mb-4 max-w-2xl mx-auto">
				Get a custom quote for your office. We'll walk through your space, understand your needs, and deliver a proposal within 48 hours.
			</p>
			<p class="text-base text-gray-500 mb-8">
				We respond to inquiries within 4 business hours.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
				<a
					href="/contact"
					class="inline-block bg-brand-orange text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-brand-orange-dark transition-all duration-300 hover:shadow-xl"
				>
					Get a Free Quote
				</a>
				<a href={contact.phone.href} class="flex items-center gap-2 font-semibold text-brand-navy hover:text-brand-orange transition-colors text-lg">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
					{contact.phone.display}
				</a>
			</div>
		</div>
	</section>

	<!-- Service Area Footer -->
	<section class="py-8 bg-gray-100">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<p class="text-gray-600">
				<strong>Serving Lake County, IL businesses:</strong> Grayslake, Libertyville, Vernon Hills, Mundelein, Waukegan, Highland Park, Lake Forest, and surrounding areas.
			</p>
		</div>
	</section>

	<!-- Final CTA -->
	<CTASection
		title="Elevate Your Workplace"
		subtitle="Professional commercial cleaning that makes you look good—without the headaches."
		buttonText="Get a Free Quote"
		buttonLink="/contact"
	/>
</BaseLayout>
