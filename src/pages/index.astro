---
import BaseLayout from '../layouts/BaseLayout.astro';
import CloudinaryImage from '../components/CloudinaryImage.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CoreValues from '../components/CoreValues.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import CTASection from '../components/CTASection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { featuredImages } from '../lib/images';
import { contact, company } from '../lib/contact';
import { serviceAreas } from '../lib/serviceAreas';

// LocalBusiness Schema
const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"@id": "https://heisergroup.com/#localbusiness",
	"name": "The Heiser Group",
	"description": "Professional house cleaning and commercial cleaning services serving Lake County, IL and Chicago suburbs since 1978. Family-owned, background-checked teams, satisfaction guaranteed.",
	"url": "https://heisergroup.com",
	"telephone": contact.phone.display,
	"email": contact.email,
	"foundingDate": "1978",
	"priceRange": "$$",
	"address": {
		"@type": "PostalAddress",
		"streetAddress": contact.address.street,
		"addressLocality": contact.address.city,
		"addressRegion": contact.address.state,
		"postalCode": contact.address.zip,
		"addressCountry": "US"
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": 42.1662,
		"longitude": -87.9631
	},
	"openingHoursSpecification": {
		"@type": "OpeningHoursSpecification",
		"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
		"opens": "09:00",
		"closes": "17:00"
	},
	"areaServed": serviceAreas.cities.map(city => ({
		"@type": "City",
		"name": city
	})),
	"sameAs": [
		contact.social.facebook,
		contact.social.linkedin
	],
	"aggregateRating": {
		"@type": "AggregateRating",
		"ratingValue": "5",
		"reviewCount": "150",
		"bestRating": "5",
		"worstRating": "1"
	},
	"hasOfferCatalog": {
		"@type": "OfferCatalog",
		"name": "Cleaning Services",
		"itemListElement": [
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Residential Cleaning",
					"url": "https://heisergroup.com/residential-cleaning"
				}
			},
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Commercial Cleaning",
					"url": "https://heisergroup.com/commercial-cleaning"
				}
			},
			{
				"@type": "Offer",
				"itemOffered": {
					"@type": "Service",
					"name": "Specialty Cleaning",
					"url": "https://heisergroup.com/specialty-cleaning"
				}
			}
		]
	}
};

// Organization Schema
const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"@id": "https://heisergroup.com/#organization",
	"name": "The Heiser Group",
	"url": "https://heisergroup.com",
	"logo": "https://heisergroup.com/logo.png",
	"foundingDate": "1978",
	"description": "Family-owned professional cleaning company serving Lake County, IL since 1978. Three generations of excellence in residential and commercial cleaning.",
	"contactPoint": {
		"@type": "ContactPoint",
		"telephone": contact.phone.display,
		"contactType": "customer service",
		"areaServed": "US",
		"availableLanguage": "English"
	},
	"sameAs": [
		contact.social.facebook,
		contact.social.linkedin
	]
};
---

<BaseLayout
	title="House Cleaning Lake County IL | Professional Cleaning Services | The Heiser Group"
	description="Professional house cleaning and commercial cleaning services in Lake County, IL. Family-owned since 1978. Same team every visit, flat-rate pricing, satisfaction guaranteed. Serving Grayslake, Libertyville, Vernon Hills & more.">
	<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

	<!-- Hero Section -->
	<section class="min-h-[90vh] flex items-center bg-gradient-to-br from-gray-50 to-white px-6 pt-24 pb-16">
		<div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
			<div>
				<!-- Social Proof Badge -->
				<div class="inline-flex items-center gap-2 bg-brand-cream px-4 py-2 rounded-full mb-6">
					<div class="flex text-brand-orange">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
					</div>
					<span class="text-sm font-medium text-gray-700">1,000+ Happy Customers</span>
				</div>

				<h1 class="text-5xl md:text-6xl lg:text-7xl font-heading text-brand-navy mb-6 font-bold leading-[1.1]">
					{company.tagline.split('.')[0]}.<br/>
					<span class="text-brand-orange">{company.tagline.split('.')[1]}.</span>
				</h1>

				<p class="text-xl text-gray-600 mb-10 leading-relaxed max-w-xl">
					Professional home and office cleaning services in Lake County, Illinois. Thorough, reliable, and backed by our satisfaction guarantee.
				</p>

				<!-- Dual CTA -->
				<div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
					<a
						href="/contact"
						class="inline-block bg-brand-orange text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-brand-orange-dark transition-all duration-300 hover:shadow-xl"
					>
						Get Your Free Quote
					</a>
					<div class="flex items-center gap-3 text-gray-600">
						<span class="hidden sm:inline">or call</span>
						<a href={contact.phone.href} class="flex items-center gap-2 font-semibold text-brand-navy hover:text-brand-orange transition-colors text-lg">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
							</svg>
							{contact.phone.display}
						</a>
					</div>
				</div>
			</div>

			{featuredImages.commercialCleaning && (
				<div class="relative">
					<CloudinaryImage
						publicId={featuredImages.commercialCleaning.publicId}
						alt="Professional Commercial Cleaning Services"
						width={700}
						height={500}
						class="rounded-2xl shadow-2xl"
					/>
					<!-- Floating stat card -->
					<div class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-xl p-4 hidden md:block">
						<div class="flex items-center gap-3">
							<div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center">
								<svg class="w-6 h-6 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
								</svg>
							</div>
							<div>
								<p class="text-2xl font-bold text-brand-navy">100%</p>
								<p class="text-sm text-gray-600">Satisfaction Guaranteed</p>
							</div>
						</div>
					</div>
				</div>
			)}
		</div>
	</section>

	<!-- Core Values -->
	<CoreValues />

	<!-- Services Section -->
	<section class="py-24 bg-gray-50">
		<div class="max-w-7xl mx-auto px-6">
			<SectionHeader
				title="Our Services"
				subtitle="Professional cleaning solutions tailored to your needs"
			/>
			<div class="grid md:grid-cols-3 gap-8">
				{featuredImages.biWeeklyCleaning && (
					<ServiceCard
						title="Residential Cleaning"
						description="Recurring home cleaning with flat-rate pricing. Come home to a spotless house every time."
						href="/residential-cleaning"
						image={{ publicId: featuredImages.biWeeklyCleaning.publicId, alt: "Residential Cleaning Services" }}
						linkText="See Options"
					/>
				)}
				{featuredImages.commercialCleaning && (
					<ServiceCard
						title="Commercial Cleaning"
						description="Office and business cleaning that keeps your workspace professional and productive."
						href="/commercial-cleaning"
						image={{ publicId: featuredImages.commercialCleaning.publicId, alt: "Commercial Cleaning Services" }}
						linkText="Get a Quote"
					/>
				)}
				{featuredImages.carpetCleaning && (
					<ServiceCard
						title="Specialty Cleaning"
						description="Deep cleaning, carpet care, and tile restoration for when you need more than routine cleaning."
						href="/specialty-cleaning"
						image={{ publicId: featuredImages.carpetCleaning.publicId, alt: "Carpet and Specialty Cleaning" }}
						linkText="Explore Services"
					/>
				)}
			</div>
		</div>
	</section>

	<!-- Testimonials -->
	<TestimonialSection />

	<!-- CTA Section -->
	<CTASection />
</BaseLayout>
