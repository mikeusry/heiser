---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CTASection from '../components/CTASection.astro';
import { contact, company } from '../lib/contact';

const title = "Realty Cleaning Services - Move-In & Move-Out | The Heiser Group";
const description = "Professional move-in/move-out cleaning for real estate agents, property managers, and homeowners in Lake County IL. Same-day availability.";

const services = [
	{
		title: "Pre-Listing Cleaning",
		description: "Get properties photo-ready with a thorough cleaning that makes every room shine for showings and listing photos.",
		icon: "sparkle" as const
	},
	{
		title: "Move-Out Cleaning",
		description: "Help sellers fulfill their contractual obligations. We handle the deep clean so closings go smoothly.",
		icon: "check" as const
	},
	{
		title: "Move-In Ready",
		description: "Ensure buyers walk into a spotless home. A clean start makes for happy clients and great referrals.",
		icon: "star" as const
	},
	{
		title: "Tenant Turnovers",
		description: "Property managers trust us for fast, thorough turnover cleaning between tenants. Minimize vacancy time.",
		icon: "calendar" as const
	}
];

const audiences = [
	{
		title: "Real Estate Agents",
		description: "Priority scheduling and flexible billing for your closings. Join our Realtor Partner Program."
	},
	{
		title: "Property Managers",
		description: "Fast turnover cleaning to minimize vacancy time. Consistent quality across all your properties."
	},
	{
		title: "Homeowners",
		description: "Moving in or out? We handle the cleaning so you can focus on your move."
	}
];

const whyPartner = [
	{
		title: "Same-Day & Next-Day Availability",
		description: "Real estate moves fast. When you need a property cleaned before a closing or showing, we're there."
	},
	{
		title: "Consistent Quality Every Time",
		description: "Your reputation is on the line. We deliver the same high standards whether it's a condo or a 5,000 sq ft home."
	},
	{
		title: "Flexible Billing Options",
		description: "We can invoice at closing, bill you directly, or bill the homeowner. Whatever works for your deal structure."
	},
	{
		title: "Before & After Documentation",
		description: "Need proof for the seller or buyer? We provide photo documentation of our work for your records."
	}
];

const faqs = [
	{
		question: "How fast can you turn around a property?",
		answer: "We offer same-day and next-day availability for our realtor partners. Call us in the morning, we can often be there that afternoon."
	},
	{
		question: "Do you offer volume pricing?",
		answer: "Yes. Real estate professionals who refer regularly receive priority scheduling and preferred rates. Ask about our Realtor Partner Program."
	},
	{
		question: "What if the property is in really bad shape?",
		answer: "We handle everything from standard move-out cleaning to disaster recovery. Just let us know what you're dealing with and we'll quote it."
	},
	{
		question: "How do I get billed?",
		answer: "Flexible options: We can invoice at closing, bill you directly, or bill the client. Whatever works for your deal."
	},
	{
		question: "What areas do you serve?",
		answer: "Lake County IL, Chicago North Shore, and Kenosha WI. Highland Park, Lake Forest, Libertyville, Northbrook, Vernon Hills, Gurnee, and surrounding areas."
	}
];

// Schema markup
const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer
		}
	}))
};

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"name": "Move-In & Move-Out Cleaning",
	"description": "Professional move-in/move-out cleaning for real estate agents, property managers, and homeowners in Lake County IL.",
	"provider": {
		"@type": "LocalBusiness",
		"name": company.name,
		"telephone": contact.phone.display,
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Grayslake",
			"addressRegion": "IL",
			"addressCountry": "US"
		}
	},
	"areaServed": [
		{ "@type": "County", "name": "Lake County", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Highland Park", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Lake Forest", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Libertyville", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Northbrook", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Vernon Hills", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Gurnee", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Kenosha", "containedIn": "Wisconsin" }
	],
	"serviceType": ["Pre-Listing Cleaning", "Move-Out Cleaning", "Move-In Cleaning", "Tenant Turnover Cleaning"]
};
---

<BaseLayout title={title} description={description}>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

	<PageHero
		eyebrow="REALTY CLEANING"
		title="Move-In & Move-Out Cleaning"
		subtitle="Professional realty cleaning for real estate agents, property managers, and homeowners. Same-day availability, consistent quality."
	/>

	<!-- Who We Serve -->
	<section class="py-20 bg-white">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader title="Who We Serve" />
			<div class="grid md:grid-cols-3 gap-8">
				{audiences.map(audience => (
					<div class="text-center p-8 bg-gray-50 rounded-xl">
						<h3 class="text-2xl font-heading font-bold text-brand-navy mb-4">{audience.title}</h3>
						<p class="text-gray-600">{audience.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Services Grid -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader
				title="Our Realty Cleaning Services"
				subtitle="From pre-listing prep to post-closing turnovers"
			/>
			<div class="grid md:grid-cols-2 gap-8">
				{services.map(service => (
					<div class="bg-white p-8 rounded-xl shadow-lg">
						<FeatureCard
							title={service.title}
							description={service.description}
							icon={service.icon}
							iconSize="lg"
						/>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Why Partner Section -->
	<section class="py-20 bg-white">
		<div class="max-w-6xl mx-auto px-6">
			<div class="max-w-3xl mx-auto text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-4">
					A Cleaning Partner, Not Just a Vendor
				</h2>
				<p class="text-xl text-gray-600">
					You've built a network of reliable vendors—photographers, stagers, inspectors. We're here to be your cleaning partner. One call, one less thing to coordinate.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8">
				{whyPartner.map((item, index) => (
					<FeatureCard
						title={item.title}
						description={item.description}
						variant="numbered"
						number={index + 1}
						iconSize="lg"
					/>
				))}
			</div>
		</div>
	</section>

	<!-- Stats/Social Proof -->
	<section class="py-20 bg-brand-navy text-white">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid md:grid-cols-3 gap-8 text-center">
				<div>
					<p class="text-5xl font-bold text-brand-orange mb-2">45+</p>
					<p class="text-xl">Years Serving Lake County</p>
				</div>
				<div>
					<p class="text-5xl font-bold text-brand-orange mb-2">1000+</p>
					<p class="text-xl">Properties Cleaned</p>
				</div>
				<div>
					<p class="text-5xl font-bold text-brand-orange mb-2">24hr</p>
					<p class="text-xl">Typical Turnaround</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="Common Questions" />
			<div class="space-y-6">
				{faqs.map(faq => (
					<div class="border-b border-gray-200 pb-6">
						<h3 class="text-xl font-heading font-bold text-brand-navy mb-2">{faq.question}</h3>
						<p class="text-gray-600">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Realtor Partner CTA -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-4">
				Real Estate Professionals: Join Our Partner Program
			</h2>
			<p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
				Priority scheduling, preferred rates, and a direct line to our team. Let's make your closings stress-free.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
				<a
					href="/contact"
					class="inline-block bg-brand-orange text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-brand-orange-dark transition-all duration-300 hover:shadow-xl"
				>
					Become a Partner
				</a>
				<a href={contact.phone.href} class="flex items-center gap-2 font-semibold text-brand-navy hover:text-brand-orange transition-colors text-lg">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
					{contact.phone.display}
				</a>
			</div>
		</div>
	</section>

	<!-- Final CTA -->
	<CTASection
		title="Ready to Get Your Property Move-In Ready?"
		subtitle="Let's talk about how The Heiser Group can handle your realty cleaning needs."
		buttonText="Get a Quote"
		buttonLink="/contact"
	/>
</BaseLayout>
