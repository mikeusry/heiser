---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CTASection from '../components/CTASection.astro';
import { contact, company } from '../lib/contact';

const title = "Realty Cleaning Services - Move-In & Move-Out | The Heiser Group";
const description = "Professional move-in/move-out cleaning for real estate agents, property managers, and homeowners in Lake County IL. Same-day availability.";

const services = [
	{
		title: "Pre-Listing Cleaning",
		description: "Get properties photo-ready with a thorough cleaning that makes every room shine for showings and listing photos.",
		icon: "sparkle" as const
	},
	{
		title: "Move-Out Cleaning",
		description: "Help sellers fulfill their contractual obligations. We handle the deep clean so closings go smoothly.",
		icon: "check" as const
	},
	{
		title: "Move-In Ready",
		description: "Ensure buyers walk into a spotless home. A clean start makes for happy clients and great referrals.",
		icon: "star" as const
	},
	{
		title: "Tenant Turnovers",
		description: "Property managers trust us for fast, thorough turnover cleaning between tenants. Minimize vacancy time.",
		icon: "calendar" as const
	}
];

const audiences = [
	{
		title: "Real Estate Agents",
		description: "Priority scheduling and flexible billing for your closings. Join our Realtor Partner Program."
	},
	{
		title: "Property Managers",
		description: "Fast turnover cleaning to minimize vacancy time. Consistent quality across all your properties."
	},
	{
		title: "Homeowners",
		description: "Moving in or out? We handle the cleaning so you can focus on your move."
	}
];

const whyPartner = [
	{
		title: "Same-Day & Next-Day Guaranteed",
		description: "Text us by 10am, we're there that afternoon. Closing tomorrow? We'll make it happen. That's our promise to realtor partners."
	},
	{
		title: "Consistent Quality Every Time",
		description: "Your reputation is on the line. We deliver the same high standards whether it's a condo or a 5,000 sq ft home."
	},
	{
		title: "Flexible Billing Options",
		description: "We can invoice at closing, bill you directly, or bill the homeowner. Whatever works for your deal structure."
	},
	{
		title: "Before & After Documentation",
		description: "Need proof for the seller or buyer? We provide photo documentation of our work for your records."
	}
];

const faqs = [
	{
		question: "How fast can you turn around a property?",
		answer: "We offer same-day and next-day availability for our realtor partners. Call us in the morning, we can often be there that afternoon."
	},
	{
		question: "Do you offer volume pricing?",
		answer: "Yes. Real estate professionals who refer regularly receive priority scheduling and preferred rates. Ask about our Realtor Partner Program."
	},
	{
		question: "What if the property is in really bad shape?",
		answer: "We handle everything from standard move-out cleaning to disaster recovery. Just let us know what you're dealing with and we'll quote it."
	},
	{
		question: "How do I get billed?",
		answer: "Flexible options: We can invoice at closing, bill you directly, or bill the client. Whatever works for your deal."
	},
	{
		question: "What areas do you serve?",
		answer: "Lake County IL, Chicago North Shore, and Kenosha WI. Highland Park, Lake Forest, Libertyville, Northbrook, Vernon Hills, Gurnee, and surrounding areas."
	}
];

// Schema markup
const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer
		}
	}))
};

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"name": "Move-In & Move-Out Cleaning",
	"description": "Professional move-in/move-out cleaning for real estate agents, property managers, and homeowners in Lake County IL.",
	"provider": {
		"@type": "LocalBusiness",
		"name": company.name,
		"telephone": contact.phone.display,
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Grayslake",
			"addressRegion": "IL",
			"addressCountry": "US"
		}
	},
	"areaServed": [
		{ "@type": "County", "name": "Lake County", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Highland Park", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Lake Forest", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Libertyville", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Northbrook", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Vernon Hills", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Gurnee", "containedIn": "Illinois" },
		{ "@type": "City", "name": "Kenosha", "containedIn": "Wisconsin" }
	],
	"serviceType": ["Pre-Listing Cleaning", "Move-Out Cleaning", "Move-In Cleaning", "Tenant Turnover Cleaning"]
};
---

<BaseLayout title={title} description={description}>
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

	<PageHero
		eyebrow="REALTY CLEANING"
		title="24-48 Hour Turnaround for Real Estate Professionals"
		subtitle="Call in the morning, cleaned by closing. We make you look good when timing is tight."
	/>

	<!-- Who We Serve -->
	<section class="py-20 bg-white">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader title="Who We Serve" />
			<div class="grid md:grid-cols-3 gap-8">
				{audiences.map(audience => (
					<div class="text-center p-8 bg-gray-50 rounded-xl">
						<h3 class="text-2xl font-heading font-bold text-brand-navy mb-4">{audience.title}</h3>
						<p class="text-gray-600">{audience.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Services Grid -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader
				title="Our Realty Cleaning Services"
				subtitle="From pre-listing prep to post-closing turnovers"
			/>
			<div class="grid md:grid-cols-2 gap-8">
				{services.map(service => (
					<div class="bg-white p-8 rounded-xl shadow-lg">
						<FeatureCard
							title={service.title}
							description={service.description}
							icon={service.icon}
							iconSize="lg"
						/>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Why Partner Section -->
	<section class="py-20 bg-white">
		<div class="max-w-6xl mx-auto px-6">
			<div class="max-w-3xl mx-auto text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-4">
					A Cleaning Partner, Not Just a Vendor
				</h2>
				<p class="text-xl text-gray-600">
					You've built a network of reliable vendors—photographers, stagers, inspectors. We're here to be your cleaning partner. One call, one less thing to coordinate.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8">
				{whyPartner.map((item, index) => (
					<FeatureCard
						title={item.title}
						description={item.description}
						variant="numbered"
						number={index + 1}
						iconSize="lg"
					/>
				))}
			</div>
		</div>
	</section>

	<!-- Case Study Feature -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-12 items-center">
				<div>
					<p class="text-brand-orange font-semibold mb-2 uppercase tracking-wide text-sm">Case Study</p>
					<h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-4">
						The Highland Park Turnover
					</h2>
					<p class="text-xl text-gray-600 mb-6">
						From "unsellable" to "under contract" in one weekend. How we transformed a neglected rental into a show-ready listing in under 24 hours.
					</p>
					<div class="grid grid-cols-2 gap-4 mb-8">
						<div class="bg-white p-4 rounded-lg">
							<p class="text-2xl font-bold text-brand-orange">18 hrs</p>
							<p class="text-sm text-gray-500">To complete</p>
						</div>
						<div class="bg-white p-4 rounded-lg">
							<p class="text-2xl font-bold text-brand-orange">$12K</p>
							<p class="text-sm text-gray-500">Over asking</p>
						</div>
					</div>
					<a href="/case-studies/highland-park-turnover" class="inline-flex items-center gap-2 text-brand-orange font-semibold hover:underline">
						Read the full case study
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
						</svg>
					</a>
				</div>
				<div class="grid grid-cols-2 gap-4">
					<div class="relative rounded-lg overflow-hidden shadow-lg">
						<img
							src="https://res.cloudinary.com/southland-organics/image/upload/w_400,h_400,c_fill,q_auto,f_auto/Heiser/Realty%20Rachel/Job%2011.12/Befores/oven"
							alt="Oven before cleaning"
							class="w-full aspect-square object-cover"
							loading="lazy"
						/>
						<span class="absolute top-2 left-2 bg-red-500 text-white px-2 py-1 rounded text-xs font-semibold">Before</span>
					</div>
					<div class="relative rounded-lg overflow-hidden shadow-lg">
						<img
							src="https://res.cloudinary.com/southland-organics/image/upload/w_400,h_400,c_fill,q_auto,f_auto/Heiser/Realty%20Rachel/Job%2011.12/Afters/oven"
							alt="Oven after cleaning"
							class="w-full aspect-square object-cover"
							loading="lazy"
						/>
						<span class="absolute top-2 left-2 bg-green-500 text-white px-2 py-1 rounded text-xs font-semibold">After</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Realtor Quote -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<svg class="w-10 h-10 text-brand-orange mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
				<path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
			</svg>
			<blockquote class="text-xl md:text-2xl text-gray-700 italic leading-relaxed mb-6">
				"David's team didn't flinch. They showed up, they worked until it was done, and they made me look like a hero to my sellers. This is the only cleaning company I recommend now."
			</blockquote>
			<cite class="not-italic">
				<span class="font-semibold text-gray-900">Sarah Mitchell</span>
				<span class="text-gray-500"> — Realtor, Coldwell Banker Highland Park</span>
			</cite>
		</div>
	</section>

	<!-- Stats/Social Proof -->
	<section class="py-20 bg-brand-navy text-white">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid md:grid-cols-3 gap-8 text-center">
				<div>
					<p class="text-5xl font-bold text-brand-orange mb-2">45+</p>
					<p class="text-xl">Years Serving Lake County</p>
				</div>
				<div>
					<p class="text-5xl font-bold text-brand-orange mb-2">1000+</p>
					<p class="text-xl">Properties Cleaned</p>
				</div>
				<div>
					<p class="text-5xl font-bold text-brand-orange mb-2">24hr</p>
					<p class="text-xl">Typical Turnaround</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader title="Common Questions" />
			<div class="space-y-6">
				{faqs.map(faq => (
					<div class="border-b border-gray-200 pb-6">
						<h3 class="text-xl font-heading font-bold text-brand-navy mb-2">{faq.question}</h3>
						<p class="text-gray-600">{faq.answer}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Realtor Partner CTA -->
	<section class="py-20 bg-brand-cream">
		<div class="max-w-4xl mx-auto px-6 text-center">
			<h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-navy mb-4">
				Realtor Partner Program
			</h2>
			<p class="text-xl text-gray-600 mb-6 max-w-2xl mx-auto">
				Skip the scheduling headaches. Partners get:
			</p>
			<ul class="text-left max-w-md mx-auto mb-8 space-y-2 text-gray-700">
				<li class="flex items-center gap-2">
					<svg class="w-5 h-5 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
					<span><strong>Direct text line</strong> to David—skip the phone tag</span>
				</li>
				<li class="flex items-center gap-2">
					<svg class="w-5 h-5 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
					<span><strong>Same-day priority</strong> when you're in a pinch</span>
				</li>
				<li class="flex items-center gap-2">
					<svg class="w-5 h-5 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
					<span><strong>Preferred rates</strong> for repeat business</span>
				</li>
				<li class="flex items-center gap-2">
					<svg class="w-5 h-5 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
					<span><strong>Flexible billing</strong>—at closing, to you, or to client</span>
				</li>
			</ul>
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
				<a
					href="/contact"
					class="inline-block bg-brand-orange text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-brand-orange-dark transition-all duration-300 hover:shadow-xl"
				>
					Become a Partner
				</a>
				<a href={contact.phone.href} class="flex items-center gap-2 font-semibold text-brand-navy hover:text-brand-orange transition-colors text-lg">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
					{contact.phone.display}
				</a>
			</div>
		</div>
	</section>

	<!-- Final CTA -->
	<CTASection
		title="Ready to Get Your Property Move-In Ready?"
		subtitle="Let's talk about how The Heiser Group can handle your realty cleaning needs."
		buttonText="Get a Quote"
		buttonLink="/contact"
	/>
</BaseLayout>
