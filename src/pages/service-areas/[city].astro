		"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
		"opens": "08:00",
		"closes": "17:00"
	}
};

// BreadcrumbList Schema
const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://heisergroup.com" },
		{ "@type": "ListItem", "position": 2, "name": "Service Areas", "item": "https://heisergroup.com/service-areas" },
		{ "@type": "ListItem", "position": 3, "name": city.name, "item": `https://heisergroup.com/service-areas/${city.slug}` }
	]
};

// FAQPage Schema
const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": city.faqs.map(faq => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer
		}
	}))
};
---

<BaseLayout title={title} description={description} pubDate={pubDate} modifiedDate={modifiedDate}>
	<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

	<PageHero
		eyebrow={`SERVING ${city.name.toUpperCase()}, ILLINOIS`}
		title={`Professional Cleaning Services in ${city.name}`}
		subtitle={`Trusted by ${city.county} families and businesses since 1978 • Just ${city.driveTime} from our office`}
	/>

	<!-- Intro Section with unique content -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<div class="prose prose-lg max-w-none">
				<p class="text-xl text-gray-700 leading-relaxed">
					{city.intro}
				</p>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section class="py-16 bg-gray-50">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader
				title={`Cleaning Services in ${city.name}`}
				subtitle="Comprehensive cleaning solutions for homes and businesses"
			/>
			<div class="grid md:grid-cols-2 gap-8">
				{services.map(service => (
					<a href={service.href} class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
						<FeatureCard
							title={service.title}
							description={service.description}
							icon={service.icon}
							iconSize="lg"
						/>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- About the City Section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader
				title={`About ${city.name}, Illinois`}
				subtitle={`Population: ${city.population} • ${city.county}`}
			/>
			<p class="text-gray-600 leading-relaxed mb-8">
				{city.aboutCity}
			</p>

			<!-- Landmarks -->
			<h3 class="font-heading font-bold text-brand-navy mb-4">Notable Landmarks</h3>
			<div class="flex flex-wrap gap-2 mb-8">
				{city.landmarks.map(landmark => (
					<span class="px-3 py-1 bg-brand-cream text-brand-navy rounded-full text-sm">
						{landmark}
					</span>
				))}
			</div>
		</div>
	</section>

	<!-- Neighborhoods Section -->
	<section class="py-16 bg-gray-50">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader
				title={`${city.name} Neighborhoods We Serve`}
			/>
			<div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4">
				{city.neighborhoods.map(area => (
					<div class="flex items-center gap-2 p-3 bg-white rounded-lg shadow-sm">
						<svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
						</svg>
						<span class="text-gray-700 text-sm">{area}</span>
					</div>
				))}
			</div>
			<p class="text-gray-500 text-sm mt-6 text-center">
				Serving ZIP codes: {city.zipCodes.join(", ")} and surrounding areas
			</p>
		</div>
	</section>

	<!-- Why Choose Us -->
	<section class="py-16 bg-brand-cream">
		<div class="max-w-6xl mx-auto px-6">
			<SectionHeader
				title={`Why ${city.name} Chooses The Heiser Group`}
			/>
			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{whyChooseUs.map(item => (
					<div class="bg-white p-6 rounded-xl shadow text-center">
						<h3 class="font-heading font-bold text-brand-navy mb-2">{item.title}</h3>
						<p class="text-gray-600 text-sm">{item.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-6">
			<SectionHeader
				title={`Frequently Asked Questions: ${city.name} Cleaning`}
			/>
			<div class="space-y-6">
				{city.faqs.map((faq, i) => (
					<div class="bg-gray-50 p-6 rounded-xl">
						<h3 class="font-heading font-bold text-brand-navy mb-2">
							{faq.question}
						</h3>
						<p class="text-gray-600">
							{faq.answer}
						</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<CTASection
		title={`Ready for a Cleaner ${city.name} Home or Office?`}
		subtitle={`Get your free, no-obligation quote today. We're just ${city.driveTime} away and ready to serve you.`}
		buttonText="Get Your Free Quote"
		buttonLink="/contact"
	/>

	<!-- Other Service Areas -->
	<section class="py-12 bg-gray-50">
		<div class="max-w-6xl mx-auto px-6">
			<h3 class="text-lg font-heading font-bold text-brand-navy mb-4 text-center">
				Also Serving Nearby Communities
			</h3>
			<div class="flex flex-wrap justify-center gap-3">
				{allCities.filter(c => c.slug !== city.slug).map(c => (
					<a
						href={`/service-areas/${c.slug}`}
						class="px-4 py-2 bg-white rounded-full text-sm text-gray-600 hover:text-brand-orange hover:shadow transition-all"
					>
						{c.name}
					</a>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
